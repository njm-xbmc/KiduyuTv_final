<?xml version="1.0" encoding="utf-8"?>
<!--
    Phone layout for TraktAuthActivity.
    Used when uiModeManager.currentModeType != Configuration.UI_MODE_TYPE_TELEVISION.
    Designed for phones and tablets (compact form factors).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_background"
    android:fitsSystemWindows="true">

    <!-- Top Header Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/auth_background"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/auth_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:text="Login Trakt"
            android:textColor="@color/auth_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sub-header: Verification URL + COPY button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/subHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/auth_subheader_bg"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/tvVerificationUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="https://trakt.tv/activate"
            android:textColor="@color/auth_text_primary"
            android:textIsSelectable="true"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCopyCode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/btnCopyCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:contentDescription="Copy URL"
            android:focusable="true"
            android:padding="8dp"
            android:text="COPY"
            android:textColor="@color/auth_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_copy"
            android:drawablePadding="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subHeader">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/loadingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="@color/trakt_red" />

                <TextView
                    android:id="@+id/tvLoadingMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Connecting to Trakt.tv..."
                    android:textColor="@color/auth_text_muted"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Device Code Container (Main state) -->
            <LinearLayout
                android:id="@+id/codeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/auth_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Trakt Icon Logo -->
                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:contentDescription="Trakt logo"
                            android:src="@drawable/trakt_logo" />

                        <!-- Trakt Wordmark Logo -->
                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="Trakt"
                            android:src="@drawable/ic_trakt_wordmark" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:gravity="center"
                            android:text="Enter the code displayed on your device."
                            android:textColor="@color/auth_text_primary"
                            android:textSize="16sp"
                            android:textStyle="italic" />

                        <!-- Code Input Field -->
                        <EditText
                            android:id="@+id/etAuthorizationCode"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="24dp"
                            android:background="@drawable/bg_trakt_input"
                            android:gravity="center"
                            android:hint="Authorization code"
                            android:inputType="textCapCharacters|textNoSuggestions"
                            android:padding="12dp"
                            android:textColor="@color/auth_text_primary"
                            android:textColorHint="@color/auth_text_dim"
                            android:textSize="16sp"
                            android:importantForAutofill="no"
                            android:autofillHints="" />

                        <!-- Open Browser button (for convenience) -->
                        <Button
                            android:id="@+id/btnOpenBrowser"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@android:color/transparent"
                            android:text="Open Trakt in Browser"
                            android:textAllCaps="false"
                            android:textColor="@color/auth_text_secondary"
                            android:textSize="14sp" />

                        <!-- Continue Button -->
                        <Button
                            android:id="@+id/btnConnect"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_trakt_button"
                            android:text="CONTINUE"
                            android:textColor="@color/auth_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPollingStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:gravity="center"
                            android:text="Open the browser, sign in, then paste the code."
                            android:textColor="@color/auth_text_dim"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Error State -->
            <LinearLayout
                android:id="@+id/errorContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="Error"
                    android:src="@drawable/ic_error"
                    app:tint="@color/auth_text_muted" />

                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Connection failed"
                    android:textColor="@color/auth_text_primary"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_trakt_button"
                    android:paddingHorizontal="32dp"
                    android:text="Retry"
                    android:textColor="@color/auth_text_primary" />

            </LinearLayout>

        </FrameLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
